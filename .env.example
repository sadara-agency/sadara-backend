# ─────────────────────────────────────────────────────────────
# .env.example — Copy to .env.development.local and fill in
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4444

# Database (must match docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=SadaraDB
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here

# JWT (use `openssl rand -base64 48` to generate)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Redis (optional — app works without it, caching disabled)
# REDIS_URL=redis://localhost:6379

# SMTP (optional — emails logged to console if not set)
# Admins can also configure SMTP at runtime via Settings → SMTP in the UI;
# DB-stored config takes precedence over these env vars.
# Encryption is auto-derived from the port (465 = implicit SSL, else STARTTLS).
# SMTP_SECURE is ignored by the app — kept only for backward compat.
#
# For Gmail: use an App Password (requires 2FA), not your account password.
#   https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com    # <-- MUST be a real address you own

# Frontend URL (for password reset links, etc.)
FRONTEND_URL=http://localhost:3000

# Encryption (use `openssl rand -hex 32` to generate)
# ENCRYPTION_KEY=your-encryption-key-here

# Sentry (optional — error tracking disabled if not set)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Wyscout (optional — match analysis provider)
# WYSCOUT_API_KEY=
# WYSCOUT_BASE_URL=https://apirest.wyscout.com/v4

# Google Cloud Storage (optional — falls back to local disk if not set)
# GCS_BUCKET=sadara-uploads
# GCS_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}  # For PaaS (Railway/Render)

# Production Admin Seed (set these in production to create the initial admin user)
# PROD_ADMIN_EMAIL=admin@sadara.com
# PROD_ADMIN_PASSWORD=your-strong-admin-password
# PROD_ADMIN_NAME=System Admin
# PROD_ADMIN_NAME_AR=مدير النظام

# Docker Compose (used by docker-compose.yml)
DB_PORT=5432
PGADMIN_EMAIL=admin@sadara.com
PGADMIN_PASSWORD=your_pgadmin_password
PGADMIN_PORT=5050
