{
  "name": "sadara-backend",
  "version": "1.0.0",
  "description": "Sadara Sports Player Management Platform — Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "build": "tsc -p tsconfig.build.json && cp -r src/assets dist/assets",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "ts-node src/database/migrate-cli.ts up",
    "migrate:down": "ts-node src/database/migrate-cli.ts down",
    "migrate:status": "ts-node src/database/migrate-cli.ts status",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@sentry/node": "^10.42.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "gradient-string": "^2.0.2",
    "helmet": "^7.1.0",
    "iconv-lite": "^0.7.2",
    "jest-util": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.38.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2",
    "winston": "^3.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/gradient-string": "^1.1.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.9.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
